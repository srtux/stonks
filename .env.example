# Google Cloud
GOOGLE_CLOUD_PROJECT=amfe-project
GOOGLE_CLOUD_REGION=us-central1

# Alpaca API (https://app.alpaca.markets/)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# SEC EDGAR (https://www.sec.gov/os/accessing-edgar-data)
SEC_EDGAR_USER_AGENT=YourName your@email.com

# BigQuery Dataset
BQ_DATASET=amfe_data

# Research Service URL (set after deploying to Cloud Run)
RESEARCH_SERVICE_URL=http://localhost:8001
